async function gasRun(fnName, args, onSuccess, onError) {
  const errHandler = onError || function(e){ showToast('error', 'Error Server', e.message || 'Terjadi kesalahan pada server'); };
  
  try {
    let result = null;
    let userId = args && args[0] ? args[0] : null;

    if (fnName === 'login') {
      const [username, password] = args;
      const { data, error } = await supabaseClient.from('users').select('*').eq('username', username).eq('password', password).eq('status', 'Active').single();
      if (error || !data) throw new Error('Username atau password salah atau akun tidak aktif');
      
      result = {
        id: data.id, userId: data.id, username: data.username, name: data.name, role: data.role, email: data.email,
        phone: data.phone, department: data.department, position: data.position, noReg: data.no_reg,
        supervisorId: data.supervisor_id, status: data.status, photoUrl: data.photo_url,
        joinDate: data.join_date, address: data.address, accessibleMenus: data.accessible_menus
      };
    } 
    else if (fnName === 'getTodayAttendance') {
      const today = getTodayStr();
      const { data, error } = await supabaseClient.from('attendance').select('*').eq('user_id', userId).eq('date', today).maybeSingle();
