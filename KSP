function updateClockUI(att) {
  const inDisplay = document.getElementById('clock-in-display');
  const outDisplay = document.getElementById('clock-out-display');
  const statusText = document.getElementById('clock-status-text');
  const statusBadge = document.getElementById('clock-status-badge');
  const actionArea = document.getElementById('clock-action-area');

  if (!att || !att.clockIn) {
    // Not clocked in
    inDisplay.textContent = '--:--';
    outDisplay.textContent = '--:--';
    statusText.textContent = 'Belum Absen';
    statusBadge.textContent = 'Belum Hadir';
    statusBadge.className = 'clock-status-badge csbadge-belum';
    actionArea.innerHTML = `<button class="btn-clock btn-clock-in" id="btn-clock-in" onclick="doClockIn()">⏱️ Clock In Sekarang</button>`;
  } else if (att.clockIn && !att.clockOut) {
    // Clocked in, not out
    inDisplay.textContent = att.clockIn;
    outDisplay.textContent = '--:--';
    document.getElementById('clock-in-loc') && (document.getElementById('clock-in-loc').textContent = att.locIn || '-');
    statusText.textContent = 'Sudah Absen Masuk';
    statusBadge.textContent = 'Sedang Bekerja';
    statusBadge.className = 'clock-status-badge csbadge-hadir';
    actionArea.innerHTML = `<button class="btn-clock btn-clock-out" id="btn-clock-out" onclick="doClockOut()">⏱️ Clock Out</button>`;
  } else {
    // Both clocked in and out
    inDisplay.textContent = att.clockIn;
    outDisplay.textContent = att.clockOut;
    document.getElementById('clock-in-loc') && (document.getElementById('clock-in-loc').textContent = att.locIn || '-');
    document.getElementById('clock-out-loc') && (document.getElementById('clock-out-loc').textContent = att.locOut || '-');
    statusText.textContent = 'Hadir';
    statusBadge.textContent = 'Selesai';
    statusBadge.className = 'clock-status-badge csbadge-selesai';
    actionArea.innerHTML = `
      <div class="work-hours-display">
        <span style="font-size:22px">⏱️</span>
        <div>
          <div class="wh-val">${formatWorkHours(att.workHours, att.clockIn, att.clockOut)}</div>
          <div class="wh-label">Total Jam Kerja</div>
        </div>
      </div>`;
  }
}

function renderAttendanceHistory(history) {
  const tbody = document.getElementById('attendance-history-body');
  if (!history || history.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">Belum ada data kehadiran</div></div></td></tr>`;
    return;
  }
  tbody.innerHTML = history.map(a => `
    <tr>
      <td>${formatDate(a.date)}</td>
      <td>${a.clockIn || '<span style="color:var(--text-secondary)">-</span>'}</td>
      <td>${a.clockOut || '<span style="color:var(--text-secondary)">-</span>'}</td>
      <td>${formatWorkHours(a.workHours, a.clockIn, a.clockOut)}</td>
      <td><span style="font-size:12px">${a.locIn || '-'}</span></td>
      <td>${(a.status === 'Hadir' || a.status === 'Present') ? '<span class="badge badge-success badge-dot">Hadir</span>' : '<span class="badge badge-warning badge-dot">Belum</span>'}</td>
    </tr>
  `).join('');
}

