  );

  // Get history
  gasRun('getMyAttendanceHistory', [user.id, 30],
    function(history) {
      renderAttendanceHistory(history);
    }, null
  );

  // Init GPS status
  initGPSStatus('gps-dot', 'gps-status-text');
