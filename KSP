function loadReportForUser(userId, startDate, endDate) {
  gasRun('getReportByDateRange', [userId, APP_STATE.user.role, startDate, endDate],
    function(rows) {
      hideLoading();
      
      const typeFilter = document.getElementById('report-type-filter').value;
      let finalRows = rows;
      if (typeFilter === 'hadir') {
        finalRows = rows.filter(r => r.status === 'Hadir' || r.clockIn);
      } else if (typeFilter === 'lembur') {
        finalRows = rows.filter(r => parseFloat(r.otHours || 0) > 0);
      } else if (typeFilter === 'cuti_izin') {
        finalRows = rows.filter(r => ['Cuti Tahunan', 'Izin', 'Sakit', 'Cuti Khusus'].includes(r.status));
      }
      
      APP_STATE.reportData = finalRows;
      APP_STATE.reportFiltered = finalRows;
      APP_STATE.reportSearch = '';
      document.getElementById('report-search').value = '';
      document.getElementById('report-page-size').value = '10';
      renderReportSummary(finalRows);
      renderReportPage(1);
      document.getElementById('export-btn').disabled = false;
    },
    (err) => { hideLoading(); showToast('error', 'Gagal', err.message || 'Gagal memuat laporan'); }
  );
}

function renderReportSummary(rows) {
  const workDays = rows.filter(r => !r.isWeekend && !r.isHoliday).length;
  const hadir = rows.filter(r => r.status === 'Hadir').length;
  const lemburJam = rows.reduce((s, r) => s + (r.otHours || 0), 0);
  const workHoursArr = rows.filter(r => r.clockIn && r.clockOut).map(r => calcWorkHoursDecimal(r.clockIn, r.clockOut));
  const avgHours = workHoursArr.length > 0 ? (workHoursArr.reduce((s,h) => s+h, 0) / workHoursArr.length).toFixed(1) : 0;

  document.getElementById('rpt-hari-kerja').textContent = workDays;
  document.getElementById('rpt-hadir').textContent = hadir;
  document.getElementById('rpt-lembur-jam').textContent = lemburJam;
  document.getElementById('rpt-avg-jam').textContent = avgHours;
  document.getElementById('report-summary').style.display = '';
  document.getElementById('report-table-card').style.display = '';
}

function handleReportSearch() {
  const q = document.getElementById('report-search').value.toLowerCase();
  APP_STATE.reportSearch = q;
  if (!APP_STATE.reportData) return;
  
  if (!q) {
    APP_STATE.reportFiltered = APP_STATE.reportData;
  } else {
    APP_STATE.reportFiltered = APP_STATE.reportData.filter(r => 
      (r.date || '').toLowerCase().includes(q) ||
      (r.day || '').toLowerCase().includes(q) ||
      (r.status || '').toLowerCase().includes(q) ||
      (r.otActivity || '').toLowerCase().includes(q)
    );
  }
  renderReportPage(1);
}

function renderReportPage(page) {
  if (!APP_STATE.reportFiltered) return;
  
  const sizeVal = document.getElementById('report-page-size').value;
  const data = APP_STATE.reportFiltered;
  
  let pagedData = data;
  let totalPages = 1;
  
  if (sizeVal !== 'all') {
    const size = parseInt(sizeVal);
    totalPages = Math.ceil(data.length / size) || 1;
    page = Math.min(Math.max(1, page), totalPages);
    const startIdx = (page - 1) * size;
    pagedData = data.slice(startIdx, startIdx + size);
  } else {
    page = 1;
  }
  
  const tbody = document.getElementById('report-table-body');
  if (pagedData.length === 0) {
    tbody.innerHTML = `<tr><td colspan="9"><div class="empty-state"><div class="empty-state-text">Tidak ada data</div></div></td></tr>`;
  } else {
    tbody.innerHTML = pagedData.map(r => {
      const rowClass = r.isWeekend || r.isHoliday ? (r.isHoliday ? 'report-row-holiday' : 'report-row-weekend') : '';
      const statusBadge = r.status === 'Hadir' ? '<span class="badge badge-success badge-dot">Hadir</span>' :
                          r.isHoliday ? '<span class="badge badge-info">Libur Nasional</span>' :
                          r.isWeekend ? '<span class="badge badge-secondary">Hari Libur</span>' :
                          (r.status === 'Sakit' || r.status === 'Izin' || r.status === 'Cuti Tahunan') ? `<span class="badge badge-warning">${r.status}</span>` :
                          '<span class="badge badge-danger badge-dot">Tidak Hadir</span>';
      const otStatus = r.otStatus === 'Approved' ? '<span class="badge badge-success">✓ Disetujui</span>' :
                       r.otStatus === 'Pending' ? '<span class="badge badge-warning">⏳ Pending</span>' :
                       r.otStatus === 'Rejected' ? '<span class="badge badge-danger">✗ Ditolak</span>' : '-';
      return `<tr class="${rowClass}">
        <td><strong style="color:var(--primary-color);">${r.userName || '-'}</strong></td>
        <td><strong>${r.date}</strong></td>
        <td>${r.day}</td>
        <td>${statusBadge}</td>
        <td>${r.clockIn || ' '}</td>
        <td>${r.clockOut || ' '}</td>
        <td>${formatWorkHours(r.workHours, r.clockIn, r.clockOut)}</td>
        <td>${r.otHours > 0 ? `<strong>${r.otHours}</strong>` : ' '}</td>
        <td style="max-width:160px;font-size:12px;">${truncate(r.otActivity, 50)}</td>
        <td>${otStatus}</td>
      </tr>`;
    }).join('');
  }
  
  // Render pagination controls
  const pagDiv = document.getElementById('report-pagination');
  if (sizeVal === 'all' || totalPages <= 1) {
    pagDiv.innerHTML = `<span style="font-size:12px;color:var(--text-secondary);line-height:32px;">Menampilkan semua ${data.length} data</span>`;
  } else {
    let html = `<span style="font-size:12px;color:var(--text-secondary);line-height:32px;margin-right:8px;">Halaman ${page} dari ${totalPages} (${data.length} total)</span>`;
    html += `<button class="btn btn-ghost btn-sm" ${page === 1 ? 'disabled' : ''} onclick="renderReportPage(${page - 1})">Prev</button>`;
    html += `<button class="btn btn-ghost btn-sm" ${page === totalPages ? 'disabled' : ''} onclick="renderReportPage(${page + 1})">Next</button>`;
    pagDiv.innerHTML = html;
  }
}

function exportReportExcel() {
  if (!APP_STATE.reportFiltered || APP_STATE.reportFiltered.length === 0) {
    showToast('warning', 'Tidak Ada Data', 'Muat laporan terlebih dahulu sebelum export'); return;
  }
  if (typeof XLSX === 'undefined') { showToast('error', 'Error', 'Library SheetJS belum dimuat'); return; }

  const startDate = document.getElementById('report-start-date').value;
  const endDate = document.getElementById('report-end-date').value;

  const headers = ['Tanggal', 'Hari', 'Status', 'Jam Masuk', 'Jam Keluar', 'Jam Kerja', 'Lembur (Jam)', 'Aktivitas Lembur', 'Status Lembur'];
  const rows = APP_STATE.reportFiltered.map(r => [
    r.date, r.day, r.status, r.clockIn || '', r.clockOut || '', r.workHours || '', r.otHours || 0, r.otActivity || '', r.otStatus || ''
  ]);

  const data = [
    [`LAPORAN ABSENSI & RIWAYAT (${startDate} s.d ${endDate})`],
    [],
    headers,
    ...rows
  ];

  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(data);
  ws['!cols'] = [{ wch: 12 }, { wch: 10 }, { wch: 15 }, { wch: 10 }, { wch: 10 }, { wch: 10 }, { wch: 12 }, { wch: 30 }, { wch: 15 }];

  XLSX.utils.book_append_sheet(wb, ws, `Laporan`);
  XLSX.writeFile(wb, `Laporan_Absensi_${startDate}_to_${endDate}.xlsx`);
  showToast('success', 'Export Berhasil!', `File Excel berhasil diunduh`);
}

