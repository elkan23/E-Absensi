    pos => {
      document.getElementById('loc-lat').value = pos.coords.latitude.toFixed(7);
      document.getElementById('loc-lng').value = pos.coords.longitude.toFixed(7);
      showToast('success', 'Lokasi Didapat', `Lat: ${pos.coords.latitude.toFixed(5)}, Lng: ${pos.coords.longitude.toFixed(5)}`);
    },
    err => showToast('error', 'GPS Error', 'Gagal mendapatkan lokasi: ' + err.message),
    { enableHighAccuracy: true, timeout: 10000 }
  );
}

