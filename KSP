let _gpsPosition = null;

function initGPSStatus(dotId, textId) {
  const dot = document.getElementById(dotId);
  const text = document.getElementById(textId);
  if (!dot || !text) return;
  if (!navigator.geolocation) {
    dot.className = 'gps-dot error';
    text.textContent = 'GPS tidak didukung browser ini';
    return;
  }
  text.textContent = 'Mendapatkan lokasi GPS...';
  navigator.geolocation.getCurrentPosition(
    pos => {
      _gpsPosition = pos;
      dot.className = 'gps-dot active';
      text.textContent = `GPS aktif - Akurasi: ${Math.round(pos.coords.accuracy)}m - (${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)})`;
    },
    err => {
      dot.className = 'gps-dot error';
      const msgs = { 1: 'Izin GPS ditolak', 2: 'GPS tidak tersedia', 3: 'GPS timeout' };
      text.textContent = msgs[err.code] || 'GPS error';
    },
    { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
  );
}

function doClockAction(type, btnId, gpsTextId, gpsDotId, onSuccess) {
  const user = APP_STATE.user;
  const btn = document.getElementById(btnId);
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span> Mendapatkan GPS...'; }

  if (!navigator.geolocation) {
    showToast('error', 'GPS Error', 'GPS tidak didukung browser ini');
    if (btn) { btn.disabled = false; btn.innerHTML = type === 'in' ? '⏱️ Clock In' : '⏱️ Clock Out'; }
    return;
  }

  navigator.geolocation.getCurrentPosition(
    pos => {
      const lat = pos.coords.latitude;
      const lng = pos.coords.longitude;
      const accuracy = Math.round(pos.coords.accuracy);

      gasRun('getLocations', [],
        function(locations) {
          let matchedLocation = null;
          let minDist = Infinity;
          if (locations && locations.length > 0) {
            for (const loc of locations) {
              const dist = calcDistance(lat, lng, loc.lat, loc.lng);
              if (dist <= loc.radius && dist < minDist) {
                minDist = dist;
                matchedLocation = loc;
              }
            }
          } else {
            matchedLocation = { name: 'Lokasi Tidak Diverifikasi' };
          }

          if (!matchedLocation && locations && locations.length > 0) {
            if (btn) { btn.disabled = false; btn.innerHTML = type === 'in' ? '⏱️ Clock In' : '⏱️ Clock Out'; }
            showToast('error', 'Di Luar Lokasi', `GPS Anda tidak berada di area lokasi kerja yang terdaftar. Akurasi: ${accuracy}m`);
            return;
          }

          if (btn) { btn.disabled = false; btn.innerHTML = type === 'in' ? '⏱️ Clock In' : '⏱️ Clock Out'; }
          showMapModal(type, lat, lng, accuracy, matchedLocation, onSuccess);
        },
        function() {
          if (btn) { btn.disabled = false; btn.innerHTML = type === 'in' ? '⏱️ Clock In' : '⏱️ Clock Out'; }
          showMapModal(type, lat, lng, accuracy, { name: 'Lokasi GPS (Offline/Fallback)' }, onSuccess);
        }
      );
    },
    err => {
      if (btn) { btn.disabled = false; btn.innerHTML = type === 'in' ? '⏱️ Clock In' : '⏱️ Clock Out'; }
      const msgs = { 1: 'Izin akses GPS ditolak. Aktifkan GPS di browser Anda.', 2: 'GPS tidak tersedia saat ini.', 3: 'GPS timeout. Coba lagi.' };
      showToast('error', 'GPS Error', msgs[err.code] || 'Gagal mendapatkan lokasi');
    },
    { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
  );
}

let leafletMap = null;
let leafletMarker = null;
let leafletCircle = null;

function showMapModal(type, lat, lng, accuracy, matchedLocation, onSuccess) {
  const modal = document.getElementById('map-modal-overlay');
  modal.classList.remove('hidden');
  document.getElementById('map-accuracy-info').textContent = `Akurasi GPS: ${accuracy} meter`;
  document.getElementById('map-location-name').textContent = matchedLocation ? matchedLocation.name : 'Unknown Location';
  
  const confirmBtn = document.getElementById('map-confirm-btn');
  confirmBtn.disabled = false;
  confirmBtn.innerHTML = type === 'in' ? '⏱️ Clock In Sekarang' : '⏱️ Clock Out Sekarang';
  
  if (!leafletMap) {
    leafletMap = L.map('map-container').setView([lat, lng], 16);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: ' OpenStreetMap'
    }).addTo(leafletMap);
  } else {
    leafletMap.setView([lat, lng], 16);
  }
  
  setTimeout(() => { leafletMap.invalidateSize(); }, 200);

  if (leafletMarker) leafletMap.removeLayer(leafletMarker);
  leafletMarker = L.marker([lat, lng]).addTo(leafletMap)
    .bindPopup('Lokasi Anda Saat Ini').openPopup();

  if (leafletCircle) leafletMap.removeLayer(leafletCircle);
  if (matchedLocation && matchedLocation.lat) {
    leafletCircle = L.circle([matchedLocation.lat, matchedLocation.lng], {
      color: 'blue',
      fillColor: '#0052cc',
      fillOpacity: 0.15,
      radius: matchedLocation.radius || 100
    }).addTo(leafletMap);
  }

  confirmBtn.onclick = function() {
    confirmBtn.disabled = true;
    confirmBtn.innerHTML = '<span class="btn-spinner"></span> Menyimpan...';
    
    const gasFn = type === 'in' ? 'clockIn' : 'clockOut';
    const locName = matchedLocation ? matchedLocation.name : 'Unknown';
    
    gasRun(gasFn, [APP_STATE.user.id, lat, lng, locName],
      function(result) {
        closeModal('map-modal-overlay');
        APP_STATE.attendanceToday = result;
        onSuccess(result);
        showToast('success', type === 'in' ? 'Clock In Berhasil!' : 'Clock Out Berhasil!', `Lokasi: ${locName}`);
      },
      function(err) {
        confirmBtn.disabled = false;
        confirmBtn.innerHTML = type === 'in' ? '⏱️ Clock In Sekarang' : '⏱️ Clock Out Sekarang';
        showToast('error', 'Gagal', err.message);
      }
    );
  };
}

