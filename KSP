  });

  // Fetch Member History (100 recent entries to paginate client-side)
  gasRun('getMyAttendanceHistory', [userId, 100], function(history) {
    svSelectedMemberHistory = history || [];
    svHistoryCurrentPage = 1;
    renderSVDynamicHistory();
    hideLoading();
  }, function() {
    hideLoading();
  });
}

function renderSVDynamicHistory() {
  const tbody = document.getElementById('sv-dyn-history-body');
  if (!tbody) return;
  
  const totalItems = svSelectedMemberHistory.length;
  if (totalItems === 0) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">Tidak ada data kehadiran</div></div></td></tr>`;
    document.getElementById('sv-dyn-pagination-info').textContent = 'Menampilkan 0-0 dari 0 entri';
    document.getElementById('sv-dyn-prev-btn').disabled = true;
    document.getElementById('sv-dyn-next-btn').disabled = true;
    return;
  }
  
  const totalPages = Math.ceil(totalItems / svHistoryPageSize);
  if (svHistoryCurrentPage < 1) svHistoryCurrentPage = 1;
  if (svHistoryCurrentPage > totalPages) svHistoryCurrentPage = totalPages;
  
  const startIndex = (svHistoryCurrentPage - 1) * svHistoryPageSize;
  const endIndex = Math.min(startIndex + svHistoryPageSize, totalItems);
  
  const pageData = svSelectedMemberHistory.slice(startIndex, endIndex);
  
  tbody.innerHTML = pageData.map(r => `
    <tr>
      <td>${formatDateLong(r.date)}</td>
      <td>${r.clockIn || '-'}</td>
      <td>${r.clockOut || '-'}</td>
      <td>${formatWorkHours(r.workHours, r.clockIn, r.clockOut)}</td>
      <td style="max-width:180px; font-size:12px;" title="${r.locIn || '-'}">${truncate(r.locIn || '-', 40)}</td>
      <td><span class="badge ${r.status !== 'Hadir' ? 'badge-warning' : 'badge-success'}">${r.status || 'Hadir'}</span></td>
    </tr>
  `).join('');
  
  document.getElementById('sv-dyn-pagination-info').textContent = `Menampilkan ${startIndex + 1}-${endIndex} dari ${totalItems} entri`;
  
  document.getElementById('sv-dyn-prev-btn').disabled = (svHistoryCurrentPage === 1);
  document.getElementById('sv-dyn-next-btn').disabled = (svHistoryCurrentPage === totalPages);
}

function changeSVDynPageSize() {
  const sizeSelect = document.getElementById('sv-dyn-pagesize');
  if (sizeSelect) {
    svHistoryPageSize = parseInt(sizeSelect.value) || 10;
    svHistoryCurrentPage = 1;
    renderSVDynamicHistory();
  }
}

function prevSVDynPage() {
  if (svHistoryCurrentPage > 1) {
    svHistoryCurrentPage--;
    renderSVDynamicHistory();
  }
}

function nextSVDynPage() {
  const totalPages = Math.ceil(svSelectedMemberHistory.length / svHistoryPageSize);
  if (svHistoryCurrentPage < totalPages) {
    svHistoryCurrentPage++;
    renderSVDynamicHistory();
  }
}

