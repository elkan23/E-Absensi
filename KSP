  const avatarEl = document.getElementById('sidebar-avatar');
  if (user.photoUrl) {
    avatarEl.innerHTML = `<img src="${user.photoUrl}" alt="${user.name}" />`;
  } else {
    avatarEl.textContent = getInitials(user.name);
  }

  // Build nav
