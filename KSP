        result = { id: data.id, userId: data.user_id, date: data.date, clockIn: data.clock_in_time, clockOut: data.clock_out_time, locIn: data.clock_in_location, locOut: data.clock_out_location, workHours: data.work_hours, status: data.status };
      }
