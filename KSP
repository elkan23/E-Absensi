    () => {
      const data = { ...emp, status: newStatus };
      showLoading('Memperbarui status...');
      gasRun('saveEmployee', [data],
        () => { hideLoading(); showToast('success', 'Berhasil', `${emp.name} berhasil di${newStatus === 'Nonaktif' ? 'nonaktif' : 'aktif'}kan`); loadEmployees(); },
        err => { hideLoading(); showToast('error', 'Gagal', err.message); }
      );
    }
  );
}

