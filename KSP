function handleApprovePwd(id, username) {
  showConfirm('❓', 'Setujui Reset Password', `Apakah Anda yakin ingin mereset password untuk user "${username}"?`, 'Setujui', 'btn-success', () => {
    showLoading('Memproses...');
    gasRun('processApproval', ['pwdrequest', id, 'approve', APP_STATE.user.id],
      () => { hideLoading(); showToast('success', 'Berhasil', 'Reset Password disetujui'); loadApprovalData(); },
      err => { hideLoading(); showToast('error', 'Gagal', err.message); }
    );
  });
}

function handleRejectPwd(id, username) {
  showConfirm('❓', 'Tolak Reset Password', `Apakah Anda yakin ingin menolak pengajuan reset password user "${username}"?`, 'Tolak', 'btn-danger', () => {
    showLoading('Memproses...');
    gasRun('processApproval', ['pwdrequest', id, 'reject', APP_STATE.user.id],
      () => { hideLoading(); showToast('info', 'Ditolak', 'Reset Password ditolak'); loadApprovalData(); },
      err => { hideLoading(); showToast('error', 'Gagal', err.message); }
    );
  });
}

function toggleSelectAllApproval(checkbox, tbodyId) {
  const tbody = document.getElementById(tbodyId);
  if (!tbody) return;
  const cbs = tbody.querySelectorAll('.approval-cb');
  cbs.forEach(cb => cb.checked = checkbox.checked);
}

function bulkApprove(type, tbodyId) {
  const tbody = document.getElementById(tbodyId);
  if (!tbody) return;
  const checked = Array.from(tbody.querySelectorAll('.approval-cb:checked')).map(cb => cb.value);
  if (checked.length === 0) return showToast('error', 'Gagal', 'Pilih minimal satu pengajuan untuk disetujui');
  showConfirm('❓', 'Setujui Terpilih', `Apakah Anda yakin ingin menyetujui ${checked.length} pengajuan terpilih?`, 'Setujui', 'btn-success', () => {
    showLoading('Memproses ' + checked.length + ' data...');
    gasRun('processBulkApproval', [type, checked, 'approve', APP_STATE.user.id],
      () => { hideLoading(); showToast('success', 'Berhasil', 'Pengajuan terpilih disetujui'); loadApprovalData(); },
      err => { hideLoading(); showToast('error', 'Gagal', err.message); }
    );
  });
}

function bulkReject(type, tbodyId) {
  const tbody = document.getElementById(tbodyId);
  if (!tbody) return;
  const checked = Array.from(tbody.querySelectorAll('.approval-cb:checked')).map(cb => cb.value);
  if (checked.length === 0) return showToast('error', 'Gagal', 'Pilih minimal satu pengajuan untuk ditolak');
  showConfirm('❓', 'Tolak Terpilih', `Apakah Anda yakin ingin menolak ${checked.length} pengajuan terpilih?`, 'Tolak', 'btn-danger', () => {
    showLoading('Memproses ' + checked.length + ' data...');
    gasRun('processBulkApproval', [type, checked, 'reject', APP_STATE.user.id],
      () => { hideLoading(); showToast('info', 'Ditolak', 'Pengajuan terpilih ditolak'); loadApprovalData(); },
      err => { hideLoading(); showToast('error', 'Gagal', err.message); }
    );
  });
}

