function submitEditAttendance() {
  const user = APP_STATE.user;
  const date = document.getElementById('edit-date').value;
  const newIn = document.getElementById('edit-new-in').value;
  const newOut = document.getElementById('edit-new-out').value;
  const reason = document.getElementById('edit-reason').value.trim();
  const errEl = document.getElementById('edit-reason-error');

  errEl.classList.add('hidden');
  document.getElementById('edit-reason').classList.remove('error');

  if (!date) { showToast('error', 'Validasi', 'Tanggal wajib dipilih'); return; }
  if (!newIn && !newOut) { showToast('error', 'Validasi', 'Minimal salah satu jam harus diisi'); return; }
  if (!reason) {
    errEl.classList.remove('hidden');
    document.getElementById('edit-reason').classList.add('error');
    document.getElementById('edit-reason').focus();
    return;
  }

  const existIn = document.getElementById('edit-existing-in').textContent;
  const existOut = document.getElementById('edit-existing-out').textContent;
  const originalIn = existIn !== '--:--' ? existIn : '';
  const originalOut = existOut !== '--:--' ? existOut : '';

  const btn = document.getElementById('edit-submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span> Mengirim...';

  gasRun('submitEditRequest', [user.id, date, originalIn, originalOut, newIn, newOut, reason],
    function(res) {
      btn.disabled = false;
      btn.innerHTML = '📤 Ajukan Koreksi';
      if (res && res.success === false) {
        showToast('error', 'Gagal', res.message);
        return;
      }
      showToast('success', 'Berhasil!', 'Pengajuan koreksi absen berhasil dikirim');
      document.getElementById('edit-reason').value = '';
      document.getElementById('edit-new-in').value = '';
      document.getElementById('edit-new-out').value = '';
      document.getElementById('edit-existing-data').classList.add('hidden');
      loadEditAttendanceView();
    },
    function(err) {
      btn.disabled = false;
      btn.innerHTML = '📤 Ajukan Koreksi';
      showToast('error', 'Gagal', err.message);
    }
  );
}

function renderEditHistory(data) {
  const showName = (isSupervisorRole(APP_STATE.user.role) || isAdminLevel(APP_STATE.user.role));
  const tbody = document.getElementById('edit-history-body');
  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">Belum ada riwayat koreksi</div></div></td></tr>`;
    return;
  }
  tbody.innerHTML = data.map(er => {
    const statusBadge = er.status === 'Approved' ? '<span class="badge badge-success badge-dot">Disetujui</span>' :
                        er.status === 'Rejected' ? '<span class="badge badge-danger badge-dot">Ditolak</span>' :
                        '<span class="badge badge-warning badge-dot">Pending</span>';
    const nameTd = showName ? `<td><strong>${er.userName || '?'}</strong></td>` : '';
    return `<tr>
      ${nameTd}
      <td>${formatDate(er.attendanceDate)}</td>
      <td>${formatDate(er.submittedAt)}</td>
      <td style="font-size:12px;">${er.originalIn || '--:--'} / ${er.originalOut || '--:--'}</td>
      <td style="font-size:12px;font-weight:700;">${er.requestedIn || '--:--'} / ${er.requestedOut || '--:--'}</td>
      <td style="max-width:180px;font-size:12px;">${truncate(er.reason, 60)}</td>
      <td>${statusBadge}</td>
      <td style="font-size:12px;">${er.note || ' '}</td>
    </tr>`;
  }).join('');
}

