function togglePwdVisibility(id) {
  const input = document.getElementById(id);
  if (input) {
    input.type = input.type === 'password' ? 'text' : 'password';
  }
}

function showForgotPasswordForm() {
  document.getElementById('login-form-container').classList.add('hidden');
  document.getElementById('forgot-password-container').classList.remove('hidden');
  
  document.getElementById('forgot-username').value = '';
  document.getElementById('forgot-email').value = '';
  document.getElementById('forgot-noreg').value = '';
  document.getElementById('forgot-new-password').value = '';
}

function hideForgotPasswordForm() {
  document.getElementById('login-form-container').classList.remove('hidden');
  document.getElementById('forgot-password-container').classList.add('hidden');
}

function submitForgotPassword() {
  const username = document.getElementById('forgot-username').value.trim();
  const email = document.getElementById('forgot-email').value.trim();
  const noreg = document.getElementById('forgot-noreg').value.trim();
  const newPassword = document.getElementById('forgot-new-password').value;

  if (!username || !email || !noreg || !newPassword) {
    showToast('error', 'Validasi Gagal', 'Semua kolom bertanda bintang (*) wajib diisi!');
    return;
  }

  if (newPassword.length < 6) {
    showToast('error', 'Validasi Gagal', 'Password baru minimal 6 karakter!');
    return;
  }

  showLoading('Sedang memverifikasi data diri...');
  gasRun('resetForgotPassword', [username, email, noreg, newPassword], function(response) {
    hideLoading();
    if (response && response.success) {
      showToast('success', 'Reset Berhasil', response.message || 'Password Anda berhasil diperbarui.');
      hideForgotPasswordForm();
      document.getElementById('login-username').value = username;
      document.getElementById('login-password').value = '';
    } else {
      showToast('error', 'Verifikasi Gagal', (response && response.message) || 'Data verifikasi tidak cocok.');
    }
  }, function(err) {
    hideLoading();
    showToast('error', 'Sistem Gagal', err.message || 'Terjadi kesalahan server.');
  });
}

function submitChangePassword() {
  const oldPassword = document.getElementById('chg-old-password').value;
  const newPassword = document.getElementById('chg-new-password').value;
  const confirmPassword = document.getElementById('chg-confirm-password').value;
  const errorDiv = document.getElementById('chg-error');
  const errorMsg = document.getElementById('chg-error-msg');

  errorDiv.classList.add('hidden');

  if (!oldPassword || !newPassword || !confirmPassword) {
    errorDiv.classList.remove('hidden');
    errorMsg.textContent = 'Semua kolom bertanda bintang (*) harus diisi!';
    return;
  }

  if (newPassword.length < 6) {
    errorDiv.classList.remove('hidden');
    errorMsg.textContent = 'Password baru minimal berukuran 6 karakter!';
    return;
  }

  if (newPassword !== confirmPassword) {
    errorDiv.classList.remove('hidden');
    errorMsg.textContent = 'Konfirmasi password baru tidak cocok!';
    return;
  }

  if (oldPassword === newPassword) {
    errorDiv.classList.remove('hidden');
    errorMsg.textContent = 'Password baru tidak boleh sama dengan password saat ini!';
    return;
  }

  if (!APP_STATE.user || !APP_STATE.user.id) {
    errorDiv.classList.remove('hidden');
    errorMsg.textContent = 'Sesi Anda telah berakhir. Silakan login kembali.';
    return;
  }

  showLoading('Sedang menyimpan password baru...');
  gasRun('changePassword', [APP_STATE.user.id, oldPassword, newPassword], function(response) {
    hideLoading();
    if (response && response.success) {
      showToast('success', 'Berhasil', response.message || 'Password Anda berhasil diperbarui.');
      
      let userRole = APP_STATE.user.role || 'Karyawan';
      if (userRole.toLowerCase() === 'admin') {
        navigateTo('view-dashboard-admin');
      } else if (userRole.indexOf('Mentor') !== -1 || userRole === 'Dept Head' || userRole === 'Div Head') {
        navigateTo('view-dashboard-supervisor');
      } else if (userRole === 'Manager' || userRole === 'General Manager' || userRole === 'Direktur' || userRole === 'Direktur Utama') {
        navigateTo('view-dashboard-supervisor');
      } else {
        navigateTo('view-dashboard-karyawan');
      }
    } else {
      errorDiv.classList.remove('hidden');
      errorMsg.textContent = (response && response.message) || 'Gagal merubah password Anda.';
    }
  }, function(err) {
    hideLoading();
    errorDiv.classList.remove('hidden');
    errorMsg.textContent = err.message || 'Terjadi kesalahan koneksi server.';
  });
}

function renderApprovalManual(data) {
  const tbody = document.getElementById('approval-manual-body');
  if (!tbody) return;
  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">Tidak ada pengajuan absen manual</div></div></td></tr>`;
    return;
  }
  tbody.innerHTML = data.map(m => {
    const statusBadge = m.status === 'Approved' ? '<span class="badge badge-success badge-dot">Disetujui</span>' :
                        m.status === 'Rejected' ? '<span class="badge badge-danger badge-dot">Ditolak</span>' :
                        `<span class="badge badge-warning badge-dot">Pending</span>`;
    let actions = m.status === 'Pending' ? `
      <div style="display:flex;gap:6px;">
        <button class="btn btn-success btn-sm" onclick="handleApproveManual('${m.id}')">✅ Setuju</button>
        <button class="btn btn-danger btn-sm" onclick="handleRejectManual('${m.id}')">❌ Tolak</button>
      </div>` : `<span style="font-size:12px;color:var(--text-secondary);">-</span>`;
    
    const cb = m.status === 'Pending' ? `<input type="checkbox" class="approval-cb" value="${m.id}">` : '';
    return `<tr>
      <td>${cb}</td>
      <td><div style="display:flex;align-items:center;gap:8px;"><div class="avatar">${getInitials(m.employeeName)}</div><span>${m.employeeName}</span></div></td>
      <td>${formatDate(m.attendanceDate || m.requestDate || '')}</td>
      <td>${m.clockIn || '--:--'} - ${m.clockOut || '--:--'}</td>
      <td><span class="badge badge-secondary">${m.type}</span></td>
      <td style="max-width:160px;font-size:12px;">${truncate(m.reason || '', 60)}</td>
      <td>${statusBadge}</td>
      <td>${actions}</td>
    </tr>`;
  }).join('');
}

function renderApprovalPassword(data) {
  const tbody = document.getElementById('approval-pwd-body');
  if (!tbody) return;
  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">Tidak ada pengajuan lupa password</div></div></td></tr>`;
    return;
  }
  tbody.innerHTML = data.map(req => {
    const actions = req.status === 'Pending' ? `
      <div style="display:flex;gap:6px;">
        <button class="btn btn-success btn-sm" onclick="handleApprovePwd('${req.id}', '${req.username}')">✅ Setuju</button>
        <button class="btn btn-danger btn-sm" onclick="handleRejectPwd('${req.id}', '${req.username}')">❌ Tolak</button>
      </div>` : `<span style="font-size:12px;color:var(--text-secondary);font-weight:600;">${req.status === 'Approved' ? '✅ Disetujui' : '❌ Ditolak'}</span>`;
    const cb = req.status === 'Pending' ? `<input type="checkbox" class="approval-cb" value="${req.id}">` : '';
    const dateStr = req.requestDate ? formatDate(req.requestDate.split(' ')[0]) + ' ' + (req.requestDate.split(' ')[1] || '').substring(0, 5) : '-';
    return `<tr>
      <td>${cb}</td>
      <td><div style="display:flex;align-items:center;gap:8px;"><div class="avatar">${getInitials(req.employeeName)}</div><span>${req.employeeName}</span></div></td>
      <td>${req.username}</td>
      <td>${req.email || '-'}</td>
      <td>${req.employeeNoReg || req.noReg || '-'}</td>
      <td>${dateStr}</td>
      <td><code style="background:#e0f2fe;color:#0369a1;padding:2px 6px;border-radius:4px;font-family:monospace;font-size:11px;">${req.newPassword}</code></td>
      <td>${actions}</td>
    </tr>`;
  }).join('');
}

