(function init() {
  gasRun('getPublicSettings', [], function(res) {
    if (res && res.success) {
      APP_STATE.publicSettings = res;
      applyPublicSettings();
    }
  });

  try {
    const savedUser = localStorage.getItem('absensi_user');
    if (savedUser) {
      APP_STATE.user = JSON.parse(savedUser);
      initApp(APP_STATE.user);
      const savedView = localStorage.getItem('absensi_current_view');
      if (savedView) navigateTo(savedView);
      return;
    }
  } catch (e) {
    localStorage.removeItem('absensi_user');
  }
  // Check if running inside GAS and already logged in
  if (typeof google !== 'undefined' && google.script && google.script.run) {
    // Could check session here
  }
  // Show login by default
  document.getElementById('view-login').style.display = 'flex';
})();
