function calcOTHours() {
  const start = document.getElementById('ot-start').value;
  const end = document.getElementById('ot-end').value;
  if (!start || !end) return;
  const [sh, sm] = start.split(':').map(Number);
  const [eh, em] = end.split(':').map(Number);
  let totalMin = (eh * 60 + em) - (sh * 60 + sm);
  if (totalMin < 0) totalMin = 0;
  const h = Math.floor(totalMin / 60);
  const m = totalMin % 60;
  document.getElementById('ot-total-hours').textContent = (totalMin / 60).toFixed(1);
  document.getElementById('ot-total-mins').textContent = `(${totalMin} menit = ${h}j ${m}m)`;
}

function submitOvertime() {
  const user = APP_STATE.user;
  const date = document.getElementById('ot-date').value;
  const start = document.getElementById('ot-start').value;
  const end = document.getElementById('ot-end').value;
  const activity = document.getElementById('ot-activity').value.trim();
  const errEl = document.getElementById('ot-activity-error');
  const btn = document.getElementById('ot-submit-btn');

  errEl.classList.add('hidden');
  document.getElementById('ot-activity').classList.remove('error');

  if (!date || !start || !end) { showToast('error', 'Validasi', 'Tanggal, jam mulai, dan jam selesai wajib diisi!'); return; }
  
  if (date !== getTodayStr()) { showToast('error', 'Validasi', 'Pengajuan lembur hanya dapat dilakukan di hari H (tidak boleh backdate / masa depan).'); return; }

  const [sh, sm] = start.split(':').map(Number);
  const [eh, em] = end.split(':').map(Number);
  const totalMin = (eh * 60 + em) - (sh * 60 + sm);
  if (totalMin <= 0) { showToast('error', 'Validasi', 'Jam selesai harus lebih dari jam mulai!'); return; }

  if (!activity) {
    errEl.classList.remove('hidden');
    document.getElementById('ot-activity').classList.add('error');
    document.getElementById('ot-activity').focus();
    return;
  }

  const totalHours = parseFloat((totalMin / 60).toFixed(2));
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span> Mengirim...';

  gasRun('submitOvertime', [user.id, date, start, end, totalHours, activity],
    function() {
      btn.disabled = false;
      btn.innerHTML = '📤 Kirim Pengajuan Lembur';
      showToast('success', 'Berhasil!', 'Pengajuan lembur berhasil dikirim dan menunggu persetujuan.');
      document.getElementById('ot-activity').value = '';
      document.getElementById('ot-start').value = '';
      document.getElementById('ot-end').value = '';
      document.getElementById('ot-total-hours').textContent = '0';
      loadOvertimeView();
    },
    function(err) {
      btn.disabled = false;
      btn.innerHTML = '📤 Kirim Pengajuan Lembur';
      showToast('error', 'Gagal', err.message);
    }
  );
}

