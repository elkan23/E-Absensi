async function loadActivityLog() {
  const tbody = document.getElementById('activity-log-body');
  if (!tbody) return;
  tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:20px">Memuat log...</td></tr>';
  // Show/hide admin column header
  const isAdminInit = isAdminLevel(APP_STATE.user.role);
  document.querySelectorAll('.log-admin-col').forEach(el => { el.style.display = isAdminInit ? '' : 'none'; });

  const user = APP_STATE.user;
  const isAdmin = isAdminLevel(user.role);

  try {
    let usersMap = {};
    if (isAdmin) {
      const { data: usersData } = await supabaseClient.from('users').select('id, name, role, department');
      if (usersData) usersData.forEach(function(u) { usersMap[u.id] = u; });
    }

    let query = supabaseClient.from('activity_logs').select('*').order('created_at', { ascending: false }).limit(200);
    if (!isAdmin) query = query.eq('user_id', user.id);

    const { data, error } = await query;
    if (error) throw error;

    if (!data || data.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:#888">Belum ada aktivitas terekam</td></tr>';
      return;
    }

    // Client-side filter
    const filterInput = document.getElementById('log-filter-user');
    const filterType = document.getElementById('log-filter-type');
    let filtered = data;
    if (filterInput && filterInput.value.trim()) {
      const q = filterInput.value.trim().toLowerCase();
      filtered = filtered.filter(function(log) {
        const u = usersMap[log.user_id];
        return (u && u.name.toLowerCase().includes(q)) || log.action_type.toLowerCase().includes(q) || log.description.toLowerCase().includes(q);
      });
    }
    if (filterType && filterType.value) {
      const ft = filterType.value;
      filtered = filtered.filter(function(log) { return log.action_type === ft; });
    }

    // Populate type dropdown
    if (filterType) {
      const types = [...new Set(data.map(function(l) { return l.action_type; }))].sort();
      const cv = filterType.value;
      filterType.innerHTML = '<option value="">-- Semua Jenis --</option>' + types.map(function(t) {
        return '<option value="' + t + '"' + (t === cv ? ' selected' : '') + '>' + t + '</option>';
      }).join('');
    }

    if (filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:#888">Tidak ada log yang cocok dengan filter</td></tr>';
      return;
    }

    tbody.innerHTML = filtered.map(function(log) {
      const u = usersMap[log.user_id];
      const userName = u ? u.name : log.user_id;
      const userRole = u ? u.role : '';
      const ac = log.action_type;
      const color = (ac.indexOf('Approve') >= 0 || ac.indexOf('Clock In') >= 0) ? '#16a34a'
        : (ac.indexOf('Reject') >= 0 || ac.indexOf('Hapus') >= 0) ? '#dc2626'
        : ac.indexOf('Pengajuan') >= 0 ? '#d97706' : '#0052cc';

      const userCol = isAdmin
        ? '<td><div style="font-weight:600;font-size:13px">' + userName + '</div><div style="font-size:11px;color:var(--text-secondary)">' + userRole + '</div></td>'
        : '';

      return '<tr>'
        + '<td style="font-size:12px;white-space:nowrap">' + new Date(log.created_at).toLocaleString('id-ID') + '</td>'
        + userCol
        + '<td><span style="font-family:monospace;font-size:11px;color:#0052cc;background:#e8f0fe;padding:2px 6px;border-radius:4px">' + log.id + '</span></td>'
        + '<td><span style="font-weight:600;color:' + color + ';font-size:12px">' + ac + '</span></td>'
        + '<td style="font-size:13px">' + log.description + '</td>'
        + '</tr>';
    }).join('');

  } catch (err) {
    console.error('Failed to load logs', err);
    tbody.innerHTML = '<tr><td colspan="5" style="color:red;text-align:center;padding:20px">Gagal memuat log: ' + err.message + '</td></tr>';
  }
}

