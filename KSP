function processExcelUpload(event, defaultRole) {
  const file = event.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const data = new Uint8Array(e.target.result);
      const workbook = XLSX.read(data, {type: 'array'});
      const firstSheetName = workbook.SheetNames[0];
      const worksheet = workbook.Sheets[firstSheetName];
      let json = XLSX.utils.sheet_to_json(worksheet, {header: 1});

      if (json.length <= 1) {
        showToast('error', 'Error', 'File Excel kosong atau format tidak valid.');
        return;
      }

      const headers = json[0].map(h => String(h).trim().toLowerCase());
      
      const empDataList = [];
      for (let i = 1; i < json.length; i++) {
        const row = json[i];
        // skip empty rows or instructional rows
        if (!row || row.length === 0 || (!row[0] && !row[2])) continue; 
        if (String(row[0]).includes('(HAPUS') || String(row[2]).includes('(HAPUS')) continue;
        
        let emp = {};
        for(let j=0; j<headers.length; j++){
           let h = headers[j] || '';
           let val = row[j] != null ? String(row[j]).trim() : '';
           
           if(h.includes('nik atasan') || h.includes('id atasan') || h.includes('username atasan')) emp.supervisor_nik = val;
           else if(h.includes('username')) emp.username = val;
           else if(h.includes('password')) emp.password = val;
           else if(h.includes('nama')) emp.name = val;
           else if(h.includes('role')) emp.role = val;
           else if(h.includes('email')) emp.email = val;
           else if((h.includes('no reg') || h.includes('nik')) && !h.includes('atasan')) emp.no_reg = val;
           else if(h.includes('departemen')) emp.department = val;
           else if(h.includes('jabatan')) emp.position = val;
           else if(h.includes('no hp')) emp.phone = val;
           else if(h.includes('alamat')) emp.address = val;
           else if(h.includes('tanggal')) emp.join_date = val;
           else if(h.includes('status')) emp.status = val;
        }

        if(!emp.name && !emp.username) continue; // safety

        if(!emp.name) {
           showToast('error', 'Error Data', `Baris ${i+1}: Nama gagal dibaca.`);
           return;
        }
        if(!emp.role) emp.role = defaultRole;
        if(!emp.join_date) {
            const tzoffset = (new Date()).getTimezoneOffset() * 60000;
            emp.join_date = (new Date(Date.now() - tzoffset)).toISOString().split('T')[0];
        }

        // Parse status to standard format for backend
        let finalStatus = 'Active';
        if (emp.status) {
           const st = String(emp.status).toLowerCase().trim();
           finalStatus = (st.includes('aktif') || st === 'active') ? 'Active' : 'Inactive';
        }

        empDataList.push({
           ...emp,
           status: finalStatus,
           leaveBalance: 12,
           accessible_menus: 'view-dashboard,view-attendance'
        });
      }

      if(empDataList.length === 0){
        showToast('warning', 'Info', 'Tidak ada data valid yang bisa diimport. (Pastikan baris contoh/instruksi sudah dihapus atau diganti).');
        event.target.value = '';
        return;
      }

      const allExist = [...(_allEmployees || []), ...(_allMentorData || [])];
      const existingUsernames = allExist.map(u => String(u.username||'').toLowerCase()).filter(u => u);

      const toUpload = [];
      const duplicates = [];
      const seenUsernamesInFile = new Set();
      
      empDataList.forEach(emp => {
          const uPattern = String(emp.username||'').toLowerCase();
          if (!uPattern) {
             toUpload.push(emp);
             return;
          }
          if (existingUsernames.includes(uPattern) || seenUsernamesInFile.has(uPattern)) {
             duplicates.push(emp.username);
          } else {
             seenUsernamesInFile.add(uPattern);
             toUpload.push(emp);
          }
      });
      
      if (duplicates.length > 0) {
         const msg = `Total data dibaca: ${empDataList.length}. Terdeteksi ${duplicates.length} baris dengan Username duplicate (sudah ada):\n[${duplicates.slice(0, 5).join(', ')}${duplicates.length > 5 ? ', ...' : ''}]\n\nApakah Anda ingin melanjutkan upload ${toUpload.length} data baru bersisa? (Data duplicate akan dilewati)`;
         showConfirm('⚠️', 'Peringatan Duplikasi', msg, 'Ya, Lanjutkan', 'btn-primary', () => {
           if(toUpload.length === 0){
              showToast('warning', 'Info', 'Semua data memiliki username yang sudah terdaftar. Tidak ada input baru yang ditarik.');
              return;
           }
           doUploadImport(toUpload);
         });
      } else {
         showConfirm('⬆️', 'Upload Data', `Membaca ${empDataList.length} baris data.\n\nApakah Anda yakin ingin mengunggah ${toUpload.length} data karyawan/mentor baru?`, 'Ya, Unggah', 'btn-primary', () => {
           if(toUpload.length === 0){
              showToast('warning', 'Info', 'Tidak ada data baru yang bisa diunggah.');
              return;
           }
           doUploadImport(toUpload);
         });
      }

      function doUploadImport(uploadList) {
         showLoading(`Mengunggah ${uploadList.length} data...`);
         gasRun('batchImportEmployees', [uploadList], function(response) {
            hideLoading();
            if(response && response.success) {
               showToast('success', 'Berhasil', `Berhasil mengimpor ${response.successCount} data. ` + (response.failCount > 0 ? `${response.failCount} gagal.` : ''));
               if(response.errors && response.errors.length > 0) {
                  console.error("Import Errors: ", response.errors);
                  showConfirm('⚠️', 'Sebagian Gagal', "Beberapa baris gagal diimpor:\n" + response.errors.slice(0, 5).join("\n") + (response.errors.length > 5 ? '\n...' : ''), 'Tutup', 'btn-ghost', () => {});
               }
               loadEmployees();
               if (typeof loadMentorList === 'function') loadMentorList();
            } else {
               showToast('error', 'Gagal Impor', response?.message || 'Terjadi kesalahan sistem');
            }
         });
      }
      
    } catch(err) {
      console.error(err);
      hideLoading();
      showToast('error', 'Parsing Error', 'Gagal membaca isi file xlsx');
    }
  };
  reader.readAsArrayBuffer(file);
  event.target.value = ''; // Reset
}

