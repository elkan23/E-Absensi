function doLogin() {
  const username = document.getElementById('login-username').value.trim();
  const password = document.getElementById('login-password').value;
  const errDiv = document.getElementById('login-error');
  const btn = document.getElementById('login-btn');

  if (!username || !password) {
    errDiv.classList.remove('hidden');
    document.getElementById('login-error-msg').textContent = 'Username dan password wajib diisi!';
    return;
  }

  errDiv.classList.add('hidden');
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span> Memproses...';

  gasRun('login', [username, password],
    function(response) {
      btn.disabled = false;
      btn.innerHTML = '🚪 Masuk';
      // Handle both formats: direct user object (mock) or {success, user} (GAS backend)
      var user = (response && response.success !== undefined) ? response.user : response;
      if (!user || (response && response.success === false)) {
        errDiv.classList.remove('hidden');
        document.getElementById('login-error-msg').textContent = (response && response.message) || 'Username atau password salah.';
        return;
      }
      // Normalize field names: backend uses snake_case, mock uses camelCase
      user.dept = user.dept || user.department || '';
      user.photoUrl = user.photoUrl || user.photo_url || '';
      user.supervisorId = user.supervisorId || user.supervisor_id || '';
      APP_STATE.user = user; localStorage.setItem('absensi_user', JSON.stringify(user));
      initApp(user);
    },
    function(err) {
      btn.disabled = false;
      btn.innerHTML = '🚪 Masuk';
      errDiv.classList.remove('hidden');
      document.getElementById('login-error-msg').textContent = err.message || 'Login gagal. Coba lagi.';
    }
  );
}


