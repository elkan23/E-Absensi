function previewPhoto(input) {
  if (input.files && input.files[0]) {
    const file = input.files[0];
    const reader = new FileReader();
    reader.onload = e => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        const MAX_WIDTH = 400;
        const MAX_HEIGHT = 400;
        let width = img.width;
        let height = img.height;

        if (width > height) {
          if (width > MAX_WIDTH) { height = Math.round(height * MAX_WIDTH / width); width = MAX_WIDTH; }
        } else {
          if (height > MAX_HEIGHT) { width = Math.round(width * MAX_HEIGHT / height); height = MAX_HEIGHT; }
        }
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);
        
        const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        document.getElementById('emp-photo-preview').src = dataUrl;
        document.getElementById('emp-photo-preview').classList.remove('hidden');
        document.getElementById('emp-photo-placeholder').style.display = 'none';
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }
}

function saveEmployee() {
  const id = document.getElementById('emp-id').value;
  const username = document.getElementById('emp-username').value.trim();
  const password = document.getElementById('emp-password').value;
  const name = document.getElementById('emp-name').value.trim();
  const email = document.getElementById('emp-email').value.trim();
  const dept = document.getElementById('emp-dept').value.trim();
  const position = document.getElementById('emp-position').value.trim();
  const role = document.getElementById('emp-role').value;

  if (!username || !name || !email || !dept || !position || !role) {
    showToast('error', 'Validasi', 'Username, nama, email, departemen, jabatan, dan role wajib diisi!'); return;
  }
  if (!id && !password) {
    showToast('error', 'Validasi', 'Password wajib diisi untuk karyawan baru!'); return;
  }

  const photoInput = document.getElementById('emp-photo-input');
  let photoBase64 = '';
  let photoFilename = '';
  if (photoInput.files && photoInput.files.length > 0) {
    photoFilename = photoInput.files[0].name;
    photoBase64 = document.getElementById('emp-photo-preview').src;
  }

  const data = {
    id: id || '', // MUST NOT BE NULL
    username: username,
    password: password || '',
    name: name,
    no_reg: document.getElementById('emp-reg-no').value.trim(),
    email: email,
    phone: document.getElementById('emp-phone').value.trim(),
    department: dept,
    position: position,
    address: document.getElementById('emp-address').value.trim(),
    join_date: document.getElementById('emp-join-date').value,
    role: role,
    supervisor_id: document.getElementById('emp-supervisor').value,
    approver_2_id: document.getElementById('emp-approver-2').value,
    approver_3_id: document.getElementById('emp-approver-3').value,
    status: document.getElementById('emp-status').value,
    leaveBalance: Number(document.getElementById('emp-leave-balance').value) || 0,
    accessible_menus: Array.from(document.getElementById('emp-menus-container').querySelectorAll('input[type="checkbox"]:checked')).map(cb => cb.value).join(','),
    photoBase64: photoBase64,
    photoFilename: photoFilename
  };

  showLoading('Menyimpan data...');
  gasRun('saveEmployee', [data],
    function(res) {
      hideLoading();
      if (res && res.success === false) {
        showToast('error', 'Gagal', res.message || 'Gagal menyimpan data karyawan');
        return;
      }
      closeModal('employee-modal-overlay');
      showToast('success', 'Berhasil!', id ? 'Data karyawan berhasil diperbarui' : 'Karyawan baru berhasil ditambahkan');
      loadEmployees();
    },
    function(err) {
      hideLoading();
      showToast('error', 'Gagal', err.message);
    }
  );
}

