  }
  if (startDate > endDate) {
    showToast('error', 'Validasi', 'Tanggal mulai tidak boleh lebih besar dari tanggal selesai!');
    return;
  }

  const user = APP_STATE.user;
  const targetId = empId === 'all' ? user.id : empId;

  showLoading('Memuat laporan...');

  if (empId === 'all') {
    gasRun('getAllEmployees', [],
      function(employees) {
        let members = isAdminLevel(user.role) ? employees : employees.filter(e => e.id !== user.id);
        const memberIds = members.map(m => m.id);
        if (memberIds.length === 0) { hideLoading(); showToast('warning', 'Info', 'Tidak ada karyawan ditemukan'); return; }
