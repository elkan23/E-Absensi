function saveMentor() {
  const id = document.getElementById('mentor-id').value;
  const name = document.getElementById('mentor-name').value.trim();
  const username = document.getElementById('mentor-username').value.trim();
  const password = document.getElementById('mentor-password').value.trim();
  const email = document.getElementById('mentor-email').value.trim();
  const role = document.getElementById('mentor-role').value;
  const status = document.getElementById('mentor-status').value;

  if (!name) { showToast('error', 'Validasi', 'Nama lengkap wajib diisi'); return; }
  if (!username) { showToast('error', 'Validasi', 'Username wajib diisi'); return; }
  if (!id && !password) { showToast('error', 'Validasi', 'Password wajib diisi untuk akun baru'); return; }
  if (password && password.length < 6) { showToast('error', 'Validasi', 'Password minimal 6 karakter'); return; }

  const btn = document.getElementById('mentor-save-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-spinner"></span> Menyimpan...';

  const payload = {
    id: id || null,
    name,
    username,
    password: password || undefined,
    email,
    role,
    status,
    // Required fields with defaults for non-employee
    department: 'Pengguna Jasa',
    position: role,
    no_reg: '',
    supervisor_id: '',
    phone: '',
    address: '',
    accessible_menus: ''
  };

  gasRun('saveMentor', [payload],
    function(res) {
      btn.disabled = false;
      btn.innerHTML = '💾 Simpan';
      if (res && res.success === false) {
        showToast('error', 'Gagal', res.message || 'Gagal menyimpan');
        return;
      }
      showToast('success', 'Berhasil', id ? 'Data User/Mentor berhasil diperbarui' : 'User/Mentor berhasil ditambahkan');
      closeModal('mentor-modal-overlay');
      loadMentorList();
    },
    function(err) {
      btn.disabled = false;
      btn.innerHTML = '💾 Simpan';
      showToast('error', 'Gagal', err.message || 'Terjadi kesalahan');
    }
  );
}

