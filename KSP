  const btn = document.getElementById('manual-submit-btn');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = 'Memproses...'; btn.disabled = true;

  gasRun('submitManualAttendance', [user.id, date, clockIn, clockOut, type, reason],
