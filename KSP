    /* ===================== CONFIRMATION DIALOG ===================== */
    .confirm-body { text-align: center; padding: 8px 0; }
    .confirm-icon { font-size: 48px; margin-bottom: 12px; }
    .confirm-title { font-size: 16px; font-weight: 800; margin-bottom: 8px; }
    .confirm-msg { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }

    /* ===================== MOBILE OVERLAY ===================== */
    #sidebar-overlay {
      display: none;
