function loadEditAttendanceView() {
  const user = APP_STATE.user;
  const today = getTodayStr();
  document.getElementById('edit-date').value = today;

  const editFormGrid = document.querySelector('#view-edit-attendance > div.admin-two-col');
  const nameTh = document.getElementById('edit-history-name-th');

  if (isSupervisorRole(user.role) || isAdminLevel(user.role)) {
    // Sembunyikan form, tampilkan kolom NAMA
    if (editFormGrid) editFormGrid.style.display = 'none';
    if (nameTh) nameTh.style.display = '';

    gasRun('getTeamEditRequests', [user.id, user.role], function(data) {
      renderEditHistory(data);
      document.getElementById('edit-stat-pending').textContent = '-';
      document.getElementById('edit-stat-approved').textContent = '-';
      document.getElementById('edit-stat-rejected').textContent = '-';
    }, null);
  } else {
    // Tampilkan form, sembunyikan kolom NAMA
    if (editFormGrid) editFormGrid.style.display = 'grid';
    if (nameTh) nameTh.style.display = 'none';

    gasRun('getMyEditRequests', [user.id], function(data) {
      renderEditHistory(data);
      const pending = data.filter(e => e.status === 'Pending').length;
      const approved = data.filter(e => e.status === 'Approved').length;
      const rejected = data.filter(e => e.status === 'Rejected').length;
      document.getElementById('edit-stat-pending').textContent = pending;
      document.getElementById('edit-stat-approved').textContent = approved;
      document.getElementById('edit-stat-rejected').textContent = rejected;
    }, null);
  }
}

