    else if (fnName === 'clockIn') {
      const [uId, lat, lng, locationName] = args;
      const today = getTodayStr();
      const time = new Date().toTimeString().substring(0,5);
      
      const { data: existing } = await supabaseClient.from('attendance').select('id').eq('user_id', uId).eq('date', today).maybeSingle();
      if (existing) throw new Error('Sudah melakukan clock in hari ini');
      
      const newId = fnName === 'clockIn' ? genId('CT') : fnName === 'submitOvertime' ? genId('OT') : genId('ID');
