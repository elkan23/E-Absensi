function renderEmployeesTable(data) {
  const tbody = document.getElementById('employees-table-body');
  const filtered = data.filter(e => {
    // Sembunyikan Pengguna Jasa (Mentor, Supervisor, Manager, dsb) dari tabel data karyawan
    const r = String(e.role || '');
    const isMentor = r.indexOf('Mentor') !== -1 || r === 'Supervisor' || r === 'Manager' || 
                     r === 'General Manager' || r === 'Direktur' || r === 'Direktur Utama' || r === 'Leader' || r === 'Dept Head' || r === 'Div Head';
    if (isMentor) return false;
    
    const matchSearch = !APP_STATE.filterEmployeeSearch ||
      e.name.toLowerCase().includes(APP_STATE.filterEmployeeSearch) ||
      (e.email || '').toLowerCase().includes(APP_STATE.filterEmployeeSearch) ||
      (e.position || '').toLowerCase().includes(APP_STATE.filterEmployeeSearch);
    const matchStatus = APP_STATE.filterEmployeeStatus === 'all' || e.status === APP_STATE.filterEmployeeStatus;
    const matchRole = APP_STATE.filterEmployeeRole === 'all' || e.role === APP_STATE.filterEmployeeRole;
    return matchSearch && matchStatus && matchRole;
  });

  if (!filtered || filtered.length === 0) {
    tbody.innerHTML = `<tr><td colspan="10"><div class="empty-state"><div class="empty-state-icon">📭</div><div class="empty-state-text">Tidak ada karyawan yang cocok dengan filter</div></div></td></tr>`;
    return;
  }

  tbody.innerHTML = filtered.map(e => {
    const supervisor = _allEmployees.find(u => u.id === e.supervisorId);
    const roleClass = e.role === 'Admin' ? 'badge-info' : 'badge-secondary';
    const avatar = e.photoUrl
      ? `<div class="avatar"><img src="${e.photoUrl}" alt="${e.name}" /></div>`
      : `<div class="avatar">${getInitials(e.name)}</div>`;
    return `<tr>
      <td><code style="font-size:12px;background:var(--bg);padding:2px 7px;border-radius:5px;">${e.noReg || '-'}</code></td>
      <td>${avatar}</td>
      <td>
        <div style="font-weight:600;">${e.name}</div>
        <div style="font-size:11px;color:var(--text-secondary);">ID: ${e.username || '-'}</div>
      </td>
      <td>${e.position || '-'}</td>
      <td>${e.dept || '-'}</td>
      <td style="font-size:12px;">${e.email || '<span style="color:var(--text-secondary)">-</span>'}</td>
      <td><span class="badge ${roleClass}">${e.role}</span></td>
      <td>${supervisor ? supervisor.name : '-'}</td>
      <td><span class="badge ${e.status === 'Aktif' ? 'badge-success' : 'badge-danger'} badge-dot">${e.status}</span></td>
