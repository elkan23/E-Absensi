    .clock-status-label { font-size: 12px; opacity: 0.75; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
    .clock-status-badge {
      padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .csbadge-hadir { background: rgba(54,179,126,0.25); color: #36B37E; border: 1px solid rgba(54,179,126,0.3); }
    .csbadge-belum { background: rgba(255,171,0,0.25); color: #FFAB00; border: 1px solid rgba(255,171,0,0.3); }
    .csbadge-selesai { background: rgba(54,179,126,0.35); color: #A0FFD0; border: 1px solid rgba(54,179,126,0.4); }
    .clock-times { display: flex; gap: 24px; margin-bottom: 20px; position: relative; z-index: 1; }
